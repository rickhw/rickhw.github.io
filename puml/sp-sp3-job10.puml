@startuml
robust "Semaphore" as SP
concise "Thread 0" as T0
concise "Thread 1" as T1
concise "Thread 2" as T2
concise "Thread 3" as T3
concise "Thread 4" as T4
legend
  millisecond
end legend
T0 has INIT,ENTERD,EXITED

@+0
SP is 0
T4 is INIT
T3 is INIT
T0 is INIT
T2 is INIT
T1 is INIT

@+4
T1 is ENTERD
SP is 1
T0 is ENTERD
T0 is EXITED

@+5
SP is 2
T2 is ENTERD

@+6
SP is 2
SP is 1
T3 is ENTERD
T2 is EXITED

@+13
SP is 2
SP is 1
T1 is EXITED
T4 is ENTERD

@+16
T3 is EXITED
SP is 1

@+23
SP is 0
T4 is EXITED

@enduml